{
  "data_dir": ".sessions",
  "user_id": "local-user",
  "channel": "cli",
  "runtime": {
    "max_tool_rounds": 5,
    "max_tool_calls_per_round": 8,
    "turn_timeout_seconds": 120,
    "max_context_tokens": 300000,
    "max_tool_result_tokens": 8000
  },
  "memory": {
    "compact_token_threshold": 200000,
    "recent_window_token_limit": 20000
  },
  "sessions": {
    "retention_days": 7
  },
  "tool_permissions": {
    "approval_required_tools": [
      "write_file",
      "edit_file",
      "exec",
      "write_stdin"
    ]
  },
  "mcp": {
    "resource_context_token_limit": 8000,
    "prompt_context_token_limit": 4000,
    "attachment_context_token_limit": 12000,
    "servers": {
      "local-example": {
        "enabled": false,
        "transport": "stdio",
        "command": "python",
        "args": ["-m", "example_mcp_server"],
        "env": {},
        "connect_retry_attempts": 3,
        "connect_retry_delay_seconds": 1,
        "connect_retry_max_delay_seconds": 8,
        "enabled_tools": []
      }
    }
  },
  "skills": {
    "directory": "skills",
    "max_loaded_skills_per_turn": 3,
    "max_skill_tokens": 8000,
    "max_loaded_skill_tokens_per_turn": 16000
  },
  "llm": {
    "provider": "openai-compatible",
    "api_key": "replace-with-your-key",
    "base_url": "https://api.openai.com/v1",
    "model": "replace-with-your-model",
    "streaming_enabled": false
  }
}
